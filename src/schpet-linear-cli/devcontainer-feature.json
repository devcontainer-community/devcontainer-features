{
    "name": "schpet/linear-cli",
    "id": "schpet-linear-cli",
    "version": "1.0.3",
    "description": "Install \"linear\" binary",
    "documentationURL": "https://github.com/devcontainer-community/devcontainer-features/tree/main/src/schpet-linear-cli",
    "options": {
        "version": {
            "type": "string",
